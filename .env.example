# =============================================================================
# DJ-D Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# --- Spotify API ---
# Get these from: https://developer.spotify.com/dashboard
# 1. Log in → Create app → Name it "DJ-D"
# 2. Set Redirect URI to: http://localhost:3000/api/auth/callback/spotify
# 3. Copy Client ID and Client Secret from the app dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# --- Anthropic (Claude AI) ---
# Get from: https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- NextAuth ---
# URL of your app (keep as-is for local development)
NEXTAUTH_URL=http://localhost:3000
# Generate a random secret: run `openssl rand -base64 32` in your terminal
NEXTAUTH_SECRET=your_random_secret_here

# --- Database (Supabase PostgreSQL) ---
# Get from: https://supabase.com → Your Project → Settings → Database → Connection String (URI mode)
# The DATABASE_URL uses connection pooling (port 6543)
DATABASE_URL=postgresql://postgres.[your-project-ref]:[your-password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# The DIRECT_URL bypasses pooling (port 5432) - used for migrations
DIRECT_URL=postgresql://postgres.[your-project-ref]:[your-password]@aws-0-[region].pooler.supabase.com:5432/postgres
